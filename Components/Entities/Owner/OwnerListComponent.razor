@inherits OwnerListViewModel

<MudTable Class="ml-4 mt-4 mr-4" Elevation="4" Items="@Owners" Dense Hover="true" Bordered="false" Filter="new Func<OwnerDto, bool>(FilterFunc)" Loading="@Loading">
    <ToolBarContent>
        <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Tertiary" Variant="Variant.Outlined" style="font-weight: bold;" OnClick="@(() => CreateOrUpdateOwner(new OwnerDto()))">
            Create new Owner
        </MudButton>
        <MudSpacer />
        <MudTextField T="string" Label="Search" Variant="Variant.Outlined" @bind-Value="SearchOwnerName" Clearable="true" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.Search"></MudTextField>
    </ToolBarContent>
    <ColGroup>
        <col />
        <col />
        <col />
        <col />
        <col style="width:2px;" />
        <col style="width:2px;" />
    </ColGroup>
    <HeaderContent>
        <MudTh style="color:var(--mud-palette-primary); font-weight: bold;">First Name</MudTh>
        <MudTh style="color:var(--mud-palette-primary); font-weight: bold;">Last Name</MudTh>
        <MudTh style="color:var(--mud-palette-primary); font-weight: bold;">Email</MudTh>
        <MudTh style="color:var(--mud-palette-primary); font-weight: bold;">Phone Number</MudTh>
        <MudTh style="color:var(--mud-palette-primary); font-weight: bold;"></MudTh>
        <MudTh style="color:var(--mud-palette-primary); font-weight: bold;"></MudTh>
    </HeaderContent>
    <RowTemplate Context="owner">
        <MudTd DataLabel="First Name">@owner.FirstName</MudTd>
        <MudTd DataLabel="Last Name">@owner.LastName</MudTd>
        <MudTd DataLabel="Email">@owner.Email</MudTd>
        <MudTd DataLabel="Phone Number">@owner.PhoneNumber</MudTd>
        
        <MudTd DataLabel="Update">
            <MudTooltip Text="Update">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => CreateOrUpdateOwner(owner))" />
            </MudTooltip>
        </MudTd>
        <MudTd DataLabel="Delete">
            <MudTooltip Text="Delete">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Primary" Size="Size.Small" OnClick="@(() => DeleteOwner(owner))" />
            </MudTooltip>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No owners found</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading...</MudText>
    </LoadingContent>
    <PagerContent>
        <MudTablePager RowsPerPageString="Items per page" InfoFormat="@InfoFormat" />
    </PagerContent>
</MudTable>
