@using MudBlazor
@inherits ServiceCenterFormViewModel

@if (ServiceCenterCreate != null && ServiceCenterCreate.ServiceCenterId == 0)
{
    <MudDialog Style="width:inherit">
        <DialogContent>
            <MudCard>
                <MudCardContent>
                    <MudItem xs="12">
                        <MudTextField Label="Name" Variant="Variant.Outlined" Immediate=true Required RequiredError=@ValidationMessage
                                      @bind-Value="ServiceCenterCreate.Name" For="@(() => ServiceCenterCreate.Name)" />

                        <MudTextField Label="Location" Variant="Variant.Outlined" Immediate=true Required RequiredError=@ValidationMessage
                                      @bind-Value="ServiceCenterCreate.Location" For="@(() => ServiceCenterCreate.Location)" />

                        <MudTextField Label="Contact Number" Variant="Variant.Outlined" Immediate=true Required RequiredError=@ValidationMessage
                                      @bind-Value="ServiceCenterCreate.ContactNumber" For="@(() => ServiceCenterCreate.ContactNumber)" />

                        <MudTextField Label="Email" Variant="Variant.Outlined" Immediate=true Required RequiredError=@ValidationMessage
                                      @bind-Value="ServiceCenterCreate.Email" For="@(() => ServiceCenterCreate.Email)" />
                    </MudItem>
                </MudCardContent>
            </MudCard>
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Tertiary" Variant="Variant.Filled" OnClick="() => Cancel()">Cancel</MudButton>
            <MudButton ButtonType="ButtonType.Submit" Disabled="@Disabled" Variant="Variant.Filled" Color="Color.Tertiary" OnClick="() => CreateOrUpdate()">Save</MudButton>
        </DialogActions>
    </MudDialog>
}
else
{
    <MudDialog Style="width:inherit">
        <DialogContent>
            <MudCard>
                <MudCardContent>
                    <MudItem xs="12">
                        <MudTextField Label="Name" Variant="Variant.Outlined" Immediate=true Required RequiredError=@ValidationMessage
                                      @bind-Value="ServiceCenterUpdate.Name" For="@(() => ServiceCenterUpdate.Name)" />

                        <MudTextField Label="Location" Variant="Variant.Outlined" Immediate=true Required RequiredError=@ValidationMessage
                                      @bind-Value="ServiceCenterUpdate.Location" For="@(() => ServiceCenterUpdate.Location)" />

                        <MudTextField Label="Contact Number" Variant="Variant.Outlined" Immediate=true Required RequiredError=@ValidationMessage
                                      @bind-Value="ServiceCenterUpdate.ContactNumber" For="@(() => ServiceCenterUpdate.ContactNumber)" />

                        <MudTextField Label="Email" Variant="Variant.Outlined" Immediate=true Required RequiredError=@ValidationMessage
                                      @bind-Value="ServiceCenterUpdate.Email" For="@(() => ServiceCenterUpdate.Email)" />
                    </MudItem>
                </MudCardContent>
            </MudCard>
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Tertiary" Variant="Variant.Filled" OnClick="() => Cancel()">Cancel</MudButton>
            <MudButton ButtonType="ButtonType.Submit" Disabled="@Disabled" Variant="Variant.Filled" Color="Color.Tertiary" OnClick="() => CreateOrUpdate()">Save</MudButton>
        </DialogActions>
    </MudDialog>
}
